# Application Configuration
APP_PORT=8080
APP_ENV=development

# Multi-Tenancy (set to false for single-tenant projects)
MULTI_TENANT_ENABLED=true
DEFAULT_TENANT_ID=default

# Database Connection
DB_HOST=localhost
DB_PORT=5432
DB_NAME=template_db
DB_USERNAME=postgres
DB_PASSWORD=postgres

# Database Connection Pool
DB_POOL_MAX_OPEN=25
DB_POOL_MAX_IDLE=5

# CORS Configuration (comma-separated)
CORS_ALLOWED_ORIGINS=http://localhost:3000,http://localhost:5173

# JWT
JWT_SECRET=change-this-to-a-secure-value-in-production

# Optional: Email Configuration (SMTP)
# Leave empty if not using email
SMTP_HOST=
SMTP_PORT=
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM_EMAIL=

# Optional: File Storage Configuration
FILE_STORAGE_TYPE=local
# For MinIO (uncomment and configure if using MinIO)
# FILE_STORAGE_TYPE=minio
# MINIO_URL=http://localhost:9000
# MINIO_BUCKET=documents
# MINIO_ACCESS_KEY=minioadmin
# MINIO_SECRET_KEY=minioadmin
# MINIO_PUBLIC_URL=http://localhost:9000
